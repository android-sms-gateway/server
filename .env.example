# Environment Configuration Template for SMSGate Server
# Copy this file to .env and fill in your actual values
# This file contains all required environment variables with examples and documentation

# =============================================================================
# GLOBAL CONFIGURATION
# =============================================================================

# Configuration file path
# Purpose: Path to the YAML configuration file
# Format: Path string
# Example: ./configs/config.yml
CONFIG_PATH=./configs/config.yml

# =============================================================================
# GATEWAY CONFIGURATION
# =============================================================================

# Gateway operation mode
# Purpose: Defines whether the gateway operates in public or private mode
# - public: Allows anonymous device registration
# - private: Requires authentication token for device registration
# Format: String (public or private)
# Default: public
# Example: private
GATEWAY__MODE=public

# Private mode registration token
# Purpose: Access token required for device registration when operating in private mode
# Format: String
# Example: 123456789
GATEWAY__PRIVATE_TOKEN=

# Upstream server URL for private mode
# Purpose: URL of the upstream server for push notifications in private mode
# Format: URL string
# Default: https://api.sms-gate.app/upstream/v1
# Example: https://api.sms-gate.app/upstream/v1
GATEWAY__UPSTREAM_URL=https://api.sms-gate.app/upstream/v1

# =============================================================================
# HTTP SERVER CONFIGURATION
# =============================================================================

# HTTP server listen address
# Purpose: Address and port the HTTP server will listen on
# Format: host:port string
# Default: :3000
# Example: 127.0.0.1:3000
HTTP__LISTEN=:3000

# Trusted proxy addresses
# Purpose: List of trusted proxy IP addresses for proper X-Forwarded-For handling
# Format: List of IP addresses
# Example: 127.0.0.1
# Example: 10.0.0.0/8
HTTP__PROXIES=127.0.0.1

# Public API host
# Purpose: Publicly accessible hostname for API (used in URLs sent to clients)
# Format: Hostname string
# Example: api.example.com
HTTP__API__HOST=

# Public API path prefix
# Purpose: API path prefix for routing
# Format: Path string
# Default: /api
# Example: /api
HTTP__API__PATH=/api

# OpenAPI documentation enabled
# Purpose: Enable or disable OpenAPI documentation endpoint
# Format: Boolean (true/false)
# Default: false
# Example: false
HTTP__OPENAPI__ENABLED=false

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database host
# Purpose: Hostname of the MySQL database server
# Format: String (hostname or IP)
# Default: localhost
# Example: localhost
DATABASE__HOST=localhost

# Database port
# Purpose: Port number of the MySQL database server
# Format: Integer
# Default: 3306
# Example: 3306
DATABASE__PORT=3306

# Database username
# Purpose: Username for database authentication
# Format: String
# Example: smsgateway
DATABASE__USER=smsgateway

# Database password
# Purpose: Password for database authentication
# Format: String
# Example: smsgateway
DATABASE__PASSWORD=smsgateway

# Database name
# Purpose: Name of the MySQL database
# Format: String
# Example: smsgateway
DATABASE__DATABASE=smsgateway

# Database timezone
# Purpose: Timezone used for database operations (important for message TTL calculation)
# Format: Timezone string (e.g., UTC, Europe/Moscow)
# Default: UTC
# Example: UTC
DATABASE__TIMEZONE=UTC

# Database debug mode
# Purpose: Enable verbose database query logging
# Format: Boolean (true/false)
# Default: false
# Example: false
DATABASE__DEBUG=false

# Database max open connections
# Purpose: Maximum number of open database connections (0 = auto-calculated based on CPU)
# Format: Integer
# Default: 0 (auto)
# Example: 4
DATABASE__MAX_OPEN_CONNS=0

# Database max idle connections
# Purpose: Maximum number of idle database connections (0 = auto-calculated based on CPU)
# Format: Integer
# Default: 0 (auto)
# Example: 2
DATABASE__MAX_IDLE_CONNS=0

# =============================================================================
# FIREBASE CLOUD MESSAGING (FCM) CONFIGURATION
# =============================================================================

# Firebase credentials JSON
# Purpose: JSON credentials for Firebase Cloud Messaging (required for public mode)
# Format: JSON string
# Example: "{}"
FCM__CREDENTIALS_JSON={}

# Push notification debounce time
# Purpose: Minimum time between push notifications to same device (prevents notification spam)
# Format: Integer (seconds, must be >= 5)
# Default: 5
# Example: 5
FCM__DEBOUNCE_SECONDS=5

# Push notification timeout
# Purpose: Timeout for sending push notifications to FCM
# Format: Integer (seconds)
# Default: 1
# Example: 1
FCM__TIMEOUT_SECONDS=1

# =============================================================================
# SERVER-SENT EVENTS (SSE) CONFIGURATION
# =============================================================================

# SSE keep-alive period
# Purpose: Interval for sending keep-alive pings to maintain SSE connections (0 to disable)
# Format: Integer (seconds)
# Default: 15
# Example: 15
SSE__KEEP_ALIVE_PERIOD_SECONDS=15

# =============================================================================
# MESSAGES CONFIGURATION
# =============================================================================

# Message cache TTL
# Purpose: Time-to-live for cached messages in seconds
# Format: Integer (seconds)
# Default: 300 (5 minutes)
# Example: 300
MESSAGES__CACHE_TTL_SECONDS=300

# Message queue max pending
# Purpose: Maximum number of pending messages in queue (0 = unlimited)
# Format: Integer
# Default: 0
# Example: 0
MESSAGES__QUEUE__MAX_PENDING=0

# Message queue max pending age
# Purpose: Maximum age of pending messages before they're considered stale
# Format: Duration (e.g., 1h, 30m)
# Default: 0
# Example: 1h
MESSAGES__QUEUE__MAX_PENDING_AGE=0s

# Message queue max failed
# Purpose: Maximum number of failed messages to retain in queue (0 = unlimited)
# Format: Integer
# Default: 0
# Example: 0
MESSAGES__QUEUE__MAX_FAILED=0

# Message queue max failed age
# Purpose: Maximum age of failed messages before deletion
# Format: Duration (e.g., 24h, 7d)
# Default: 0
# Example: 24h
MESSAGES__QUEUE__MAX_FAILED_AGE=0s

# Message queue stats refresh interval
# Purpose: Interval for refreshing queue statistics
# Format: Duration (e.g., 5s, 1m)
# Default: 5s
# Example: 5s
MESSAGES__QUEUE__STATS_REFRESH_INTERVAL=5s

# Message queue stats cache TTL
# Purpose: Time-to-live for cached queue statistics
# Format: Duration (e.g., 30s, 1m)
# Default: 60s
# Example: 60s
MESSAGES__QUEUE__STATS_CACHE_TTL=60s

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Cache URL
# Purpose: Connection URL for caching layer (memory:// for in-memory, redis:// for Redis)
# Format: URL string
# Default: memory://
# Example: memory://
# Example: redis://localhost:6379/0
CACHE__URL=memory://

# =============================================================================
# PUB/SUB CONFIGURATION
# =============================================================================

# Pub/Sub URL
# Purpose: Connection URL for pub/sub messaging (memory:// for in-memory, redis:// for Redis)
# Format: URL string
# Default: memory://
# Example: memory://
# Example: redis://localhost:6379/1
PUBSUB__URL=memory://

# Pub/Sub buffer size
# Purpose: Buffer size for pub/sub message handling
# Format: Integer
# Default: 128
# Example: 128
PUBSUB__BUFFER_SIZE=128

# =============================================================================
# JWT AUTHENTICATION CONFIGURATION
# =============================================================================

# JWT secret key
# Purpose: Secret key for signing JWT tokens (leave empty to disable JWT functionality)
# Format: String (min 32 characters recommended)
# Example: your-secret-key-here-min-32-chars
JWT__SECRET=

# JWT access token TTL
# Purpose: Time-to-live for access tokens
# Format: Duration (e.g., 15m, 1h)
# Default: 15m
# Example: 15m
JWT__ACCESS_TTL=15m

# JWT refresh token TTL
# Purpose: Time-to-live for refresh tokens
# Format: Duration (e.g., 720h, 30d)
# Default: 720h (30 days)
# Example: 720h
JWT__REFRESH_TTL=720h

# JWT issuer
# Purpose: Issuer claim for JWT tokens (typically your domain)
# Format: String
# Example: sms-gate.app
JWT__ISSUER=sms-gate.app

# =============================================================================
# OTP (ONE-TIME PASSWORD) CONFIGURATION
# =============================================================================

# OTP TTL
# Purpose: Time-to-live for one-time passwords in seconds
# Format: Integer (seconds)
# Default: 300 (5 minutes)
# Example: 300
OTP__TTL=300

# OTP retries
# Purpose: Number of retry attempts for OTP generation (handles collision)
# Format: Integer
# Default: 3
# Example: 3
OTP__RETRIES=3

# =============================================================================
# WORKER TASKS CONFIGURATION
# =============================================================================

# Messages hashing task interval
# Purpose: Interval for running the messages hashing task (duplicate detection)
# Format: Duration (e.g., 168h, 7d)
# Default: 168h (7 days)
# Example: 168h
TASKS__MESSAGES_HASHING__INTERVAL=168h

# Messages cleanup task interval
# Purpose: Interval for running the messages cleanup task
# Format: Duration (e.g., 24h, 1d)
# Default: 24h (1 day)
# Example: 24h
TASKS__MESSAGES_CLEANUP__INTERVAL=24h

# Messages cleanup max age
# Purpose: Maximum age of messages before deletion
# Format: Duration (e.g., 720h, 30d)
# Default: 720h (30 days)
# Example: 720h
TASKS__MESSAGES_CLEANUP__MAX_AGE=720h

# Devices cleanup task interval
# Purpose: Interval for running the devices cleanup task
# Format: Duration (e.g., 24h, 1d)
# Default: 24h (1 day)
# Example: 24h
TASKS__DEVICES_CLEANUP__INTERVAL=24h

# Devices cleanup max age
# Purpose: Maximum age of inactive devices before removal
# Format: Duration (e.g., 8760h, 365d)
# Default: 8760h (365 days)
# Example: 8760h
TASKS__DEVICES_CLEANUP__MAX_AGE=8760h
